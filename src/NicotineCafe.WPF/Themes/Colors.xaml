<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nicotine Cafe — premium dark palette v2 -->
    <Color x:Key="BgDeepColor">#07080B</Color>
    <Color x:Key="BgPanelColor">#12141B</Color>
    <Color x:Key="BgPanelTopColor">#1A1D27</Color>
    <Color x:Key="AccentGoldColor">#D9B25C</Color>
    <Color x:Key="AccentGoldBrightColor">#F3D385</Color>
    <Color x:Key="AccentEmberColor">#E0603F</Color>
    <Color x:Key="AccentTealColor">#3FA796</Color>
    <Color x:Key="TextPrimaryColor">#F6F4EF</Color>
    <Color x:Key="TextMutedColor">#8E93A1</Color>
    <Color x:Key="TextFaintColor">#565B69</Color>
    <Color x:Key="BorderColor">#22262F</Color>

    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeepColor}" />
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanelColor}" />
    <SolidColorBrush x:Key="AccentGoldBrush" Color="{StaticResource AccentGoldColor}" />
    <SolidColorBrush x:Key="AccentGoldBrightBrush" Color="{StaticResource AccentGoldBrightColor}" />
    <SolidColorBrush x:Key="AccentEmberBrush" Color="{StaticResource AccentEmberColor}" />
    <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTealColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}" />
    <SolidColorBrush x:Key="BorderBrush2" Color="{StaticResource BorderColor}" />

    <!-- Deep radial vignette background -->
    <RadialGradientBrush x:Key="BgGradientBrush" GradientOrigin="0.5,0.38" Center="0.5,0.38" RadiusX="0.9" RadiusY="0.9">
        <GradientStop Color="#181B24" Offset="0" />
        <GradientStop Color="#0C0D12" Offset="0.55" />
        <GradientStop Color="#07080B" Offset="1" />
    </RadialGradientBrush>

    <LinearGradientBrush x:Key="PanelGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource BgPanelTopColor}" Offset="0" />
        <GradientStop Color="{StaticResource BgPanelColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GoldGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#D9B25C" Offset="0" />
        <GradientStop Color="#F3D385" Offset="0.5" />
        <GradientStop Color="#D9B25C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="EmberGoldGradientBrush" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="#E0603F" Offset="0" />
        <GradientStop Color="#D9B25C" Offset="1" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="OrbCoreGradientBrush" GradientOrigin="0.5,0.5" Center="0.5,0.5">
        <GradientStop Color="#F3D385" Offset="0" />
        <GradientStop Color="#D9B25C" Offset="0.55" />
        <GradientStop Color="#00000000" Offset="1" />
    </RadialGradientBrush>
</ResourceDictionary>
