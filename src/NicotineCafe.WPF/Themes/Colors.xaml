<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nicotine Cafe — dark, premium palette -->
    <Color x:Key="BgDeepColor">#0B0D12</Color>
    <Color x:Key="BgPanelColor">#14171F</Color>
    <Color x:Key="AccentGoldColor">#D4AF37</Color>
    <Color x:Key="AccentEmberColor">#E85D3D</Color>
    <Color x:Key="TextPrimaryColor">#F5F3EE</Color>
    <Color x:Key="TextMutedColor">#8B8F9B</Color>
    <Color x:Key="BorderColor">#262B36</Color>

    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeepColor}" />
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanelColor}" />
    <SolidColorBrush x:Key="AccentGoldBrush" Color="{StaticResource AccentGoldColor}" />
    <SolidColorBrush x:Key="AccentEmberBrush" Color="{StaticResource AccentEmberColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="BorderBrush2" Color="{StaticResource BorderColor}" />

    <LinearGradientBrush x:Key="BgGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B0D12" Offset="0" />
        <GradientStop Color="#171A22" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GoldGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#D4AF37" Offset="0" />
        <GradientStop Color="#F1D06B" Offset="0.5" />
        <GradientStop Color="#D4AF37" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
