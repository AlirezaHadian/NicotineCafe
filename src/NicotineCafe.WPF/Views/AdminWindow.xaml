<Window x:Class="NicotineCafe.WPF.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="مدیریت برندها — نیکوتین کافه" Width="1280" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgGradientBrush}"
        FlowDirection="RightToLeft" FontFamily="{DynamicResource FontBody}">

    <TabControl Background="Transparent" BorderThickness="0" Margin="20">

    <!-- ============================== برندها ============================== -->
    <TabItem Header="برندها">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="1.3*" />
        </Grid.ColumnDefinitions>

        <!-- Brand list -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="لیست برندها" Style="{StaticResource BrandLogoStyle}"
                       FontSize="20" Margin="0,0,0,14" />
            <DataGrid ItemsSource="{Binding Brands}" SelectedItem="{Binding SelectedBrand}"
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                      Background="#12141B" Foreground="{DynamicResource TextPrimaryBrush}"
                      RowBackground="#12141B" AlternatingRowBackground="#161923"
                      BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                      GridLinesVisibility="None" HeadersVisibility="Column">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1E2230" />
                        <Setter Property="Foreground" Value="{DynamicResource AccentGoldBrightBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="10,10" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="10,6" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2A2F3D" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="نام فارسی" Binding="{Binding NameFa}" Width="*" />
                    <DataGridTextColumn Header="نام انگلیسی" Binding="{Binding NameEn}" Width="*" />
                    <DataGridTextColumn Header="عکس" Binding="{Binding ImagePath}" Width="*" />
                    <DataGridTextColumn Header="ویدیو" Binding="{Binding VideoPath}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Add/Edit + Aliases + Models -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- Brand form -->
            <Border Background="{DynamicResource PanelGradientBrush}" CornerRadius="18"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="افزودن / ویرایش برند" Style="{StaticResource BrandLogoStyle}" FontSize="18" Margin="0,0,0,18" />

                    <TextBlock Text="نام فارسی" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding FormNameFa, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="نام انگلیسی" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding FormNameEn}" FlowDirection="LeftToRight" Margin="0,0,0,12" />

                    <TextBlock Text="عکس برند" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding FormImagePath}" FlowDirection="LeftToRight" IsReadOnly="True" />
                        <Button Grid.Column="2" Content="انتخاب فایل..." Command="{Binding BrowseForImageCommand}" Padding="16,8" />
                    </Grid>

                    <TextBlock Text="ویدیوی دمو برند (اختیاری — بعد از ۱ دقیقه به‌صورت لوپ پخش می‌شه)"
                               Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" TextWrapping="Wrap" />
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding FormVideoPath}" FlowDirection="LeftToRight" IsReadOnly="True" />
                        <Button Grid.Column="2" Content="انتخاب فایل..." Command="{Binding BrowseForVideoCommand}" Padding="16,8" />
                        <Button Grid.Column="4" Content="حذف" Command="{Binding ClearVideoCommand}" Padding="16,8"
                                Background="{DynamicResource AccentEmberBrush}" />
                    </Grid>

                    <UniformGrid Columns="2" Rows="1">
                        <Button Content="افزودن برند جدید" Command="{Binding SaveNewCommand}" Padding="0,10" Margin="0,0,6,0" />
                        <Button Content="ذخیره تغییرات" Command="{Binding SaveChangesCommand}" Padding="0,10" Margin="6,0,0,0" />
                    </UniformGrid>
                    <UniformGrid Columns="2" Rows="1" Margin="0,8,0,0">
                        <Button Content="حذف برند انتخاب‌شده" Command="{Binding DeleteSelectedCommand}"
                                Padding="0,10" Margin="0,0,6,0" Background="{DynamicResource AccentEmberBrush}" />
                        <Button Content="پاک‌کردن فرم" Command="{Binding ClearFormCommand}" Padding="0,10" Margin="6,0,0,0" />
                    </UniformGrid>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource AccentGoldBrightBrush}"
                               Margin="0,16,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Aliases -->
            <Border Background="{DynamicResource PanelGradientBrush}" CornerRadius="18"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="الیاس‌ها (تلفظ‌های عامیانه که موتور صدا باید بشناسه)"
                               Style="{StaticResource BrandLogoStyle}" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,14" />
                    <ItemsControl ItemsSource="{Binding SelectedBrandAliases}" Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E2230" CornerRadius="14" Padding="10,5" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Alias}" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                        <Button Content="✕" Margin="8,0,0,0" Width="20" Height="20" Padding="0" FontSize="10"
                                                Background="Transparent" Foreground="{DynamicResource TextFaintBrush}" BorderThickness="0"
                                                Command="{Binding DataContext.DeleteAliasCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewAliasText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2" Content="افزودن الیاس" Command="{Binding AddAliasCommand}" Padding="16,8" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Models we carry -->
            <Border Background="{DynamicResource PanelGradientBrush}" CornerRadius="18"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Padding="24">
                <StackPanel>
                    <TextBlock Text="مدل‌هایی که از این برند داریم (زیر اسم برند نشون داده می‌شه)"
                               Style="{StaticResource BrandLogoStyle}" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,14" />
                    <ItemsControl ItemsSource="{Binding SelectedBrandModels}" Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E2230" CornerRadius="14" Padding="10,5" Margin="0,0,8,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding ModelName}" Foreground="{DynamicResource AccentGoldBrightBrush}" VerticalAlignment="Center" />
                                        <Button Content="✕" Margin="8,0,0,0" Width="20" Height="20" Padding="0" FontSize="10"
                                                Background="Transparent" Foreground="{DynamicResource TextFaintBrush}" BorderThickness="0"
                                                Command="{Binding DataContext.DeleteModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewModelText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2" Content="افزودن مدل" Command="{Binding AddModelCommand}" Padding="16,8" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>
    </Grid>
    </TabItem>

    <!-- ============================== تنظیمات ============================== -->
    <TabItem Header="تنظیمات موتور تشخیص گفتار">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Background="{DynamicResource PanelGradientBrush}" CornerRadius="18"
                BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Padding="30" Margin="12"
                MaxWidth="620" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="تنظیمات موتور صدا" Style="{StaticResource BrandLogoStyle}" FontSize="18" Margin="0,0,0,6" />
                <TextBlock Text="تغییرات بعد از بستن و باز کردن دوباره‌ی برنامه اعمال می‌شن (موتور صدا نیاز به ری‌استارت داره)."
                           Style="{StaticResource SpecLabelStyle}" TextWrapping="Wrap" Margin="0,0,0,20" />

                <TextBlock Text="اندازه‌ی مدل — tiny / base / small (tiny = سریع‌ترین، small = دقیق‌ترین)" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding SettingModelSize}" Margin="0,0,0,16" FlowDirection="LeftToRight" />

                <TextBlock Text="Beam Size (۱ = سریع، ۵ = دقیق‌تر ولی کندتر)" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding SettingBeamSize}" Margin="0,0,0,16" FlowDirection="LeftToRight" />

                <TextBlock Text="آستانه‌ی تشخیص صدا (۰ تا ۱ — پایین‌تر = حساس‌تر به صدای کم)" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding SettingSpeechThreshold}" Margin="0,0,0,16" FlowDirection="LeftToRight" />

                <TextBlock Text="مکث سکوت برای پایان گفتار (ثانیه)" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding SettingSilenceHangoverS}" Margin="0,0,0,16" FlowDirection="LeftToRight" />

                <TextBlock Text="حداقل طول گفتار برای پردازش (ثانیه)" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding SettingMinUtteranceS}" Margin="0,0,0,16" FlowDirection="LeftToRight" />

                <TextBlock Text="تعداد هسته‌ی CPU برای موتور صدا" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding SettingCpuThreads}" Margin="0,0,0,16" FlowDirection="LeftToRight" />

                <TextBlock Text="حداقل اطمینان برای پذیرفتن یک تشخیص (۰ تا ۱)" Style="{StaticResource SpecLabelStyle}" Margin="0,0,0,4" />
                <TextBox Text="{Binding SettingMinConfidence}" Margin="0,0,0,16" FlowDirection="LeftToRight" />

                <CheckBox Content="زیر اسم برند، لیست مدل‌های موجود رو نشون بده" IsChecked="{Binding SettingShowModelList}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24" />

                <Button Content="ذخیره‌ی تنظیمات" Command="{Binding SaveSettingsCommand}" Padding="0,10" />

                <TextBlock Text="{Binding SettingsStatusMessage}" Foreground="{DynamicResource AccentGoldBrightBrush}"
                           Margin="0,16,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        </ScrollViewer>
    </TabItem>

    </TabControl>
</Window>
