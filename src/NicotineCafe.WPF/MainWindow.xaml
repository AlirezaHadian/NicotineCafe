<Window x:Class="NicotineCafe.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NicotineCafe.WPF.Controls"
        Title="Nicotine Cafe" WindowState="Maximized" WindowStyle="None"
        Background="{DynamicResource BgGradientBrush}"
        FlowDirection="RightToLeft" FontFamily="{DynamicResource FontBody}">

    <Window.Resources>
        <Storyboard x:Key="ProcessingPulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ProcessingDot" Storyboard.TargetProperty="Opacity"
                             From="1" To="0.25" Duration="0:0:0.6" AutoReverse="True" />
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar — deliberately LTR regardless of the RTL content below,
             so it reads like a normal Windows title bar: brand on the left,
             window controls on the right. -->
        <Grid Grid.Row="0" Margin="32,24,32,0" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="34" Height="34" CornerRadius="10" Background="{DynamicResource GoldGradientBrush}"
                        Margin="0,0,12,0">
                    <TextBlock Text="N" FontWeight="Bold" FontSize="18" Foreground="#0B0D12"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="NICOTINE CAFÉ" FontFamily="{DynamicResource FontDisplay}"
                           FontSize="19" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center"
                         Fill="{Binding IsEngineConnected, Converter={StaticResource ConnectionDotConverter}}" />
                <TextBlock Text="{Binding IsEngineConnected, Converter={StaticResource ConnectionTextConverter}}"
                           FontSize="12" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"
                           Margin="0,0,20,0" />

                <Button Content="{Binding IsPaused, Converter={StaticResource PauseResumeTextConverter}}"
                        Command="{Binding ToggleListeningCommand}" Style="{StaticResource TopBarPillButtonStyle}" />
                <Button Content="⚙" ToolTip="مدیریت برندها" Click="AdminButton_Click"
                        Style="{StaticResource TopBarIconButtonStyle}" />
                <Border Width="1" Height="20" Background="{DynamicResource BorderBrush2}" Margin="8,0" />
                <Button Content="—" ToolTip="کوچک‌کردن" Click="MinimizeButton_Click"
                        Style="{StaticResource TopBarIconButtonStyle}" />
                <Button Content="✕" ToolTip="خروج از برنامه" Click="CloseButton_Click"
                        Style="{StaticResource TopBarCloseButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- Center content -->
        <Grid Grid.Row="1">

            <!-- Idle / listening state: orb + status text, no button needed -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsProductVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <controls:AudioEqualizerControl Level="{Binding AudioLevel}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusTextStyle}"
                           HorizontalAlignment="Center" Margin="0,28,0,0" />
            </StackPanel>

            <!-- Brand card: recognition is brand-only now — the customer
                 sees the BRAND (name + image) plus a "what we carry" list
                 of models underneath (toggle: ShowModelList), no specs. -->
            <Border x:Name="ProductCard" MaxWidth="1120" Padding="56"
                    Background="{DynamicResource PanelGradientBrush}"
                    BorderBrush="{DynamicResource AccentGoldBrush}" BorderThickness="1.5"
                    CornerRadius="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ProductCardScale" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsProductVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)"
                                                From="0.94" To="1" Duration="0:0:0.28">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)"
                                                From="0.94" To="1" Duration="0:0:0.28">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                From="0" To="1" Duration="0:0:0.32" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="80" ShadowDepth="0" Opacity="0.35" Color="#D9B25C" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Brand image -->
                    <Border Grid.Column="0" CornerRadius="20" Background="#0C0E14" ClipToBounds="True"
                            BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Height="360">
                        <Image Source="{Binding CurrentBrand.ImagePath, Converter={StaticResource ImagePathToSourceConverter}}"
                               Stretch="Uniform" Margin="16" />
                    </Border>

                    <!-- Details -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Border Width="46" Height="4" CornerRadius="2" HorizontalAlignment="Right"
                                Background="{DynamicResource GoldGradientBrush}" Margin="0,0,0,18" />
                        <TextBlock Text="{Binding CurrentBrand.NameFa}" Style="{StaticResource TitleTextStyle}" />
                        <TextBlock Text="{Binding CurrentBrand.NameEn}" Style="{StaticResource SubTitleTextStyle}"
                                   FlowDirection="LeftToRight" HorizontalAlignment="Right" Margin="0,6,0,36" />

                        <StackPanel Visibility="{Binding ShowModelList, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="این مدل‌ها رو از این برند داریم:" Style="{StaticResource SpecLabelStyle}"
                                       FontSize="15" Margin="0,0,0,12" />

                            <ItemsControl ItemsSource="{Binding CurrentBrand.ModelNames}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E2230" BorderBrush="{DynamicResource BorderBrush2}"
                                                BorderThickness="1" CornerRadius="16" Padding="16,8" Margin="0,0,10,10">
                                            <TextBlock Text="{Binding}" FontSize="16"
                                                       Foreground="{DynamicResource AccentGoldBrightBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Close (X) button -->
            <Button Style="{StaticResource CloseButtonStyle}"
                    Command="{Binding CloseProductCommand}"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,80,80,0" Content="✕" FontSize="16" />

            <!-- "Processing" pill — visible in EVERY state (idle screen OR
                 on top of an already-showing brand card). Previously this
                 feedback only reached the idle screen's status text, so a
                 customer speaking while a brand card was up got no
                 indication anything was happening at all. -->
            <Border Style="{StaticResource ProcessingPillStyle}"
                    Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,28,0,0">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ProcessingDot" Width="9" Height="9" VerticalAlignment="Center"
                             Fill="{DynamicResource AccentGoldBrightBrush}" Margin="0,0,10,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard Storyboard="{StaticResource ProcessingPulseStoryboard}" />
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="در حال پردازش..." FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Brand demo-video POPUP — big, full-screen-style overlay, not a
             small inline swap. Appears once this brand's card has been on
             screen for ~1 minute (see MainViewModel.IsShowingBrandVideo) and
             that brand has a video configured (Admin screen). Automatically
             goes away the moment a new brand is recognised or the card is
             closed — no manual close button needed. -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Background="#D9070809"
              Visibility="{Binding IsShowingBrandVideo, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border MaxWidth="1500" MaxHeight="900" Margin="60" CornerRadius="24"
                    Background="#0C0E14" BorderBrush="{DynamicResource AccentGoldBrush}" BorderThickness="1.5"
                    ClipToBounds="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="90" ShadowDepth="0" Opacity="0.5" Color="#D9B25C" />
                </Border.Effect>
                <Grid>
                    <MediaElement x:Name="BrandVideoElement" Stretch="Uniform"
                                  LoadedBehavior="Manual" UnloadedBehavior="Manual"
                                  MediaEnded="BrandVideoElement_MediaEnded"
                                  MediaFailed="BrandVideoElement_MediaFailed" />

                    <!-- Brand name label, top-left of the popup, so it's
                         clear which product this demo belongs to. -->
                    <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="24"
                            Background="#C0000000" CornerRadius="14" Padding="16,9">
                        <TextBlock Text="{Binding CurrentBrand.NameFa}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="نیکوتین کافه — تشخیص هوشمند محصول با صدا"
                   Foreground="{DynamicResource TextFaintBrush}" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,0,0,26" />
    </Grid>
</Window>
