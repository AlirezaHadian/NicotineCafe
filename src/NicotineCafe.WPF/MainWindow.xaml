<Window x:Class="NicotineCafe.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NicotineCafe.WPF.Controls"
        Title="Nicotine Cafe" WindowState="Maximized" WindowStyle="None"
        Background="{DynamicResource BgGradientBrush}"
        FlowDirection="RightToLeft" FontFamily="{DynamicResource FontBody}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar: brand + live equalizer -->
        <Grid Grid.Row="0" Margin="40,30,40,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="نیکوتین کافه" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AccentGoldBrush}" />
            <controls:AudioEqualizerControl Grid.Column="1" Width="140" Height="40"
                                             Level="{Binding AudioLevel}" />
        </Grid>

        <!-- Center content -->
        <Grid Grid.Row="1">

            <!-- Idle state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsProductVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubTitleTextStyle}"
                           HorizontalAlignment="Center" Margin="0,0,0,30" />
                <Button x:Name="MicButton" Width="120" Height="120" Cursor="Hand"
                        PreviewMouseLeftButtonDown="MicButton_PressStart"
                        PreviewMouseLeftButtonUp="MicButton_PressEnd">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Ellipse Fill="{DynamicResource GoldGradientBrush}" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock Text="🎙" FontSize="40" HorizontalAlignment="Center" Margin="0,-84,0,0" IsHitTestVisible="False" />
            </StackPanel>

            <!-- Product card -->
            <Border x:Name="ProductCard" MaxWidth="1000" Padding="50"
                    Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="0" Opacity="0.5" Color="#000000" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Product image -->
                    <Border Grid.Column="0" CornerRadius="16" Background="#0000" ClipToBounds="True">
                        <Image Source="{Binding CurrentProduct.ImagePath}" Stretch="Uniform" />
                    </Border>

                    <!-- Details -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentProduct.NameFa}" Style="{StaticResource TitleTextStyle}" />
                        <TextBlock Text="{Binding CurrentProduct.NameEn}" Style="{StaticResource SubTitleTextStyle}"
                                   FlowDirection="LeftToRight" Margin="0,4,0,20" />

                        <!-- Spec grid -->
                        <UniformGrid Columns="3" Rows="1" Margin="0,10,0,0">
                            <StackPanel Margin="0,0,24,0">
                                <TextBlock Text="قطران" Style="{StaticResource SpecLabelStyle}" />
                                <TextBlock Text="{Binding CurrentProduct.TarMg, StringFormat={}{0} mg}"
                                           Style="{StaticResource SpecValueStyle}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,24,0">
                                <TextBlock Text="نیکوتین" Style="{StaticResource SpecLabelStyle}" />
                                <TextBlock Text="{Binding CurrentProduct.NicotineMg, StringFormat={}{0} mg}"
                                           Style="{StaticResource SpecValueStyle}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="مونوکسیدکربن" Style="{StaticResource SpecLabelStyle}" />
                                <TextBlock Text="{Binding CurrentProduct.CarbonMonoxideMg, StringFormat={}{0} mg}"
                                           Style="{StaticResource SpecValueStyle}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Close (X) button — top-right corner of the card -->
            <Button Style="{StaticResource CloseButtonStyle}"
                    Command="{Binding CloseProductCommand}"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,60,60,0" Content="✕" FontSize="18" />
        </Grid>
    </Grid>
</Window>
