<Window x:Class="NicotineCafe.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NicotineCafe.WPF.Controls"
        Title="Nicotine Cafe" WindowState="Maximized" WindowStyle="None"
        Background="{DynamicResource BgGradientBrush}"
        FlowDirection="RightToLeft" FontFamily="{DynamicResource FontBody}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar — deliberately LTR regardless of the RTL content below,
             so it reads like a normal Windows title bar: brand on the left,
             window controls on the right. -->
        <Grid Grid.Row="0" Margin="32,24,32,0" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="34" Height="34" CornerRadius="10" Background="{DynamicResource GoldGradientBrush}"
                        Margin="0,0,12,0">
                    <TextBlock Text="N" FontWeight="Bold" FontSize="18" Foreground="#0B0D12"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="NICOTINE CAFÉ" FontFamily="{DynamicResource FontDisplay}"
                           FontSize="19" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center"
                         Fill="{Binding IsEngineConnected, Converter={StaticResource ConnectionDotConverter}}" />
                <TextBlock Text="{Binding IsEngineConnected, Converter={StaticResource ConnectionTextConverter}}"
                           FontSize="12" Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"
                           Margin="0,0,20,0" />

                <Button Content="{Binding IsPaused, Converter={StaticResource PauseResumeTextConverter}}"
                        Command="{Binding ToggleListeningCommand}" Style="{StaticResource TopBarPillButtonStyle}" />
                <Button Content="⚙" ToolTip="مدیریت برندها" Click="AdminButton_Click"
                        Style="{StaticResource TopBarIconButtonStyle}" />
                <Border Width="1" Height="20" Background="{DynamicResource BorderBrush2}" Margin="8,0" />
                <Button Content="—" ToolTip="کوچک‌کردن" Click="MinimizeButton_Click"
                        Style="{StaticResource TopBarIconButtonStyle}" />
                <Button Content="✕" ToolTip="خروج از برنامه" Click="CloseButton_Click"
                        Style="{StaticResource TopBarCloseButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- Center content -->
        <Grid Grid.Row="1">

            <!-- Idle / listening state: orb + status text, no button needed -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsProductVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <controls:AudioEqualizerControl Level="{Binding AudioLevel}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusTextStyle}"
                           HorizontalAlignment="Center" Margin="0,28,0,0" />
            </StackPanel>

            <!-- Brand card: recognition is brand-only now — the customer
                 sees the BRAND (name + image) plus a "what we carry" list
                 of models underneath (toggle: ShowModelList), no specs. -->
            <Border x:Name="ProductCard" MaxWidth="1120" Padding="56"
                    Background="{DynamicResource PanelGradientBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    CornerRadius="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="70" ShadowDepth="0" Opacity="0.55" Color="#000000" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Brand image -->
                    <Border Grid.Column="0" CornerRadius="20" Background="#0C0E14" ClipToBounds="True"
                            BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Height="360">
                        <Image Source="{Binding CurrentBrand.ImagePath, Converter={StaticResource ImagePathToSourceConverter}}"
                               Stretch="Uniform" Margin="16" />
                    </Border>

                    <!-- Details -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentBrand.NameFa}" Style="{StaticResource TitleTextStyle}" />
                        <TextBlock Text="{Binding CurrentBrand.NameEn}" Style="{StaticResource SubTitleTextStyle}"
                                   FlowDirection="LeftToRight" HorizontalAlignment="Right" Margin="0,6,0,36" />

                        <StackPanel Visibility="{Binding ShowModelList, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="این مدل‌ها رو از این برند داریم:" Style="{StaticResource SpecLabelStyle}"
                                       FontSize="15" Margin="0,0,0,12" />

                            <ItemsControl ItemsSource="{Binding CurrentBrand.ModelNames}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E2230" BorderBrush="{DynamicResource BorderBrush2}"
                                                BorderThickness="1" CornerRadius="16" Padding="16,8" Margin="0,0,10,10">
                                            <TextBlock Text="{Binding}" FontSize="16"
                                                       Foreground="{DynamicResource AccentGoldBrightBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Close (X) button -->
            <Button Style="{StaticResource CloseButtonStyle}"
                    Command="{Binding CloseProductCommand}"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,80,80,0" Content="✕" FontSize="16" />
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="نیکوتین کافه — تشخیص هوشمند محصول با صدا"
                   Foreground="{DynamicResource TextFaintBrush}" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,0,0,26" />
    </Grid>
</Window>
