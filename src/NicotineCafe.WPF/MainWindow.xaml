<Window x:Class="NicotineCafe.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NicotineCafe.WPF.Controls"
        Title="Nicotine Cafe" WindowState="Maximized" WindowStyle="None"
        Background="{DynamicResource BgGradientBrush}"
        FlowDirection="RightToLeft" FontFamily="{DynamicResource FontBody}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="56,42,56,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="{DynamicResource AccentGoldBrush}" Margin="0,0,10,0" />
                <TextBlock Text="نیکوتین کافه" Style="{StaticResource BrandLogoStyle}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                         Fill="{Binding IsEngineConnected, Converter={StaticResource ConnectionDotConverter}}" />
                <TextBlock Text="{Binding IsEngineConnected, Converter={StaticResource ConnectionTextConverter}}"
                           FontSize="13" Foreground="{DynamicResource TextFaintBrush}" Margin="0,0,18,0" />
                <Button Content="⚙" FontSize="16" Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="{DynamicResource TextFaintBrush}"
                        Click="AdminButton_Click" ToolTip="مدیریت محصولات" />
            </StackPanel>
        </Grid>

        <!-- Center content -->
        <Grid Grid.Row="1">

            <!-- Idle / listening state: orb + status text, no button needed -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsProductVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <controls:AudioEqualizerControl Level="{Binding AudioLevel}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusTextStyle}"
                           HorizontalAlignment="Center" Margin="0,28,0,0" />
            </StackPanel>

            <!-- Product card -->
            <Border x:Name="ProductCard" MaxWidth="1120" Padding="56"
                    Background="{DynamicResource PanelGradientBrush}"
                    BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1"
                    CornerRadius="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="70" ShadowDepth="0" Opacity="0.55" Color="#000000" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Product image -->
                    <Border Grid.Column="0" CornerRadius="20" Background="#0C0E14" ClipToBounds="True"
                            BorderBrush="{DynamicResource BorderBrush2}" BorderThickness="1" Height="360">
                        <Image Source="{Binding CurrentProduct.ImagePath}" Stretch="Uniform" Margin="16" />
                    </Border>

                    <!-- Details -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Border Background="#1E2230" CornerRadius="20" Padding="14,6" HorizontalAlignment="Right" Margin="0,0,0,18">
                            <TextBlock Text="{Binding CurrentProduct.BrandNameFa}"
                                       FontSize="14" Foreground="{DynamicResource AccentGoldBrightBrush}" />
                        </Border>

                        <TextBlock Text="{Binding CurrentProduct.NameFa}" Style="{StaticResource TitleTextStyle}" />
                        <TextBlock Text="{Binding CurrentProduct.NameEn}" Style="{StaticResource SubTitleTextStyle}"
                                   FlowDirection="LeftToRight" HorizontalAlignment="Right" Margin="0,6,0,32" />

                        <!-- Spec badges -->
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource SpecBadgeBorderStyle}" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="قطران" Style="{StaticResource SpecLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentProduct.TarMg, StringFormat={}{0} mg}"
                                               Style="{StaticResource SpecValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SpecBadgeBorderStyle}" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="نیکوتین" Style="{StaticResource SpecLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentProduct.NicotineMg, StringFormat={}{0} mg}"
                                               Style="{StaticResource SpecValueStyle}" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SpecBadgeBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="مونوکسیدکربن" Style="{StaticResource SpecLabelStyle}" />
                                    <TextBlock Text="{Binding CurrentProduct.CarbonMonoxideMg, StringFormat={}{0} mg}"
                                               Style="{StaticResource SpecValueStyle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Close (X) button -->
            <Button Style="{StaticResource CloseButtonStyle}"
                    Command="{Binding CloseProductCommand}"
                    Visibility="{Binding IsProductVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,80,80,0" Content="✕" FontSize="16" />
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="نیکوتین کافه — تشخیص هوشمند محصول با صدا"
                   Foreground="{DynamicResource TextFaintBrush}" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,0,0,26" />
    </Grid>
</Window>
