<UserControl x:Class="NicotineCafe.WPF.Controls.AudioEqualizerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <!--
        Bar-style "listening equalizer" — minimal: no background glow/shape,
        just a small row of gold bars, anchored to the bottom, each with its
        own idle phase so they move independently rather than in lockstep.
        All react together to the live mic RMS (Level, 0..1). Passive
        indicator only — nothing to press.
    -->
    <Grid Width="200" Height="90">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Border x:Name="Bar1" Width="10" Height="16" Margin="4,0" CornerRadius="5" VerticalAlignment="Bottom"
                    Background="{DynamicResource GoldGradientBrush}" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform><ScaleTransform x:Name="Bar1Scale" ScaleY="1" /></Border.RenderTransform>
            </Border>
            <Border x:Name="Bar2" Width="10" Height="16" Margin="4,0" CornerRadius="5" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentGoldBrightBrush}" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform><ScaleTransform x:Name="Bar2Scale" ScaleY="1" /></Border.RenderTransform>
            </Border>
            <Border x:Name="Bar3" Width="10" Height="16" Margin="4,0" CornerRadius="5" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentGoldBrightBrush}" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform><ScaleTransform x:Name="Bar3Scale" ScaleY="1" /></Border.RenderTransform>
            </Border>
            <Border x:Name="Bar4" Width="11" Height="18" Margin="4,0" CornerRadius="5.5" VerticalAlignment="Bottom"
                    Background="{DynamicResource GoldGradientBrush}" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform><ScaleTransform x:Name="Bar4Scale" ScaleY="1" /></Border.RenderTransform>
            </Border>
            <Border x:Name="Bar5" Width="10" Height="16" Margin="4,0" CornerRadius="5" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentGoldBrightBrush}" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform><ScaleTransform x:Name="Bar5Scale" ScaleY="1" /></Border.RenderTransform>
            </Border>
            <Border x:Name="Bar6" Width="10" Height="16" Margin="4,0" CornerRadius="5" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentGoldBrightBrush}" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform><ScaleTransform x:Name="Bar6Scale" ScaleY="1" /></Border.RenderTransform>
            </Border>
            <Border x:Name="Bar7" Width="10" Height="16" Margin="4,0" CornerRadius="5" VerticalAlignment="Bottom"
                    Background="{DynamicResource GoldGradientBrush}" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform><ScaleTransform x:Name="Bar7Scale" ScaleY="1" /></Border.RenderTransform>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
